        {
          "name": "List Files",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});",
                  "",
                  "var json = pm.response.json();",
                  "if (json.length > 0) {",
                  "    pm.test('File objects have expected fields', function () {",
                  "        var f = json[0];",
                  "        pm.expect(f).to.have.property('key');",
                  "        pm.expect(f).to.have.property('size_bytes');",
                  "        pm.expect(f).to.have.property('last_modified');",
                  "        pm.expect(f.size_bytes).to.be.above(0);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/files",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "files"]
            },
            "description": "Admin-only: list all uploaded files from the configured storage backend (local disk or S3). Returns file key, size, and last modified timestamp.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/admin/audit-logs?limit=50&offset=0",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "audit-logs"],
              "query": [
                {
                  "key": "entity_type",
                  "value": "lead",
                  "description": "Filter by entity type (lead, user)",
                  "disabled": true
