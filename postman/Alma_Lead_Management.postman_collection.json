    {
      "name": "Storage",
      "item": [
        {
          "name": "Create Lead — Verify S3 Storage",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.test('Resume URL points to auth-protected endpoint', function () {",
                  "        pm.expect(json.resume_url).to.be.a('string');",
                  "        pm.expect(json.resume_url).to.include('/api/leads/');",
                  "        pm.expect(json.resume_url).to.include('/resume-url');",
                  "    });",
                  "    pm.test('Raw S3 key is not exposed', function () {",
                  "        pm.expect(json).to.not.have.property('resume_path');",
                  "    });",
                  "    pm.test('Lead has PENDING state', function () {",
                  "        pm.expect(json.state).to.eql('PENDING');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "first_name",
                  "value": "S3",
                  "type": "text"
                },
                {
                  "key": "last_name",
                  "value": "Storage",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "s3-test@example.com",
                  "type": "text"
                },
                {
                  "key": "resume",
                  "type": "file",
                  "src": "",
                  "description": "Select a PDF or DOCX file"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/leads",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"]
            },
            "description": "Submit a lead and verify the response includes an auth-protected `resume_url`. The raw S3 key is never exposed. Make sure S3_BUCKET is set in your .env."
          },
          "response": []
        },
        {
          "name": "Create Lead — Invalid File Type",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Error mentions file type', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.detail).to.include('not allowed');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "multipart/form-data"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "first_name",
                  "value": "Bad",
                  "type": "text"
                },
                {
                  "key": "last_name",
                  "value": "File",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "badfile@example.com",
                  "type": "text"
                },
                {
                  "key": "resume",
                  "type": "file",
                  "src": "",
                  "description": "Select a NON-PDF/DOCX file (e.g. .txt, .jpg) to test rejection"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/leads",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"]
            },
            "description": "Negative test — upload an invalid file type. Should return 400 with 'not allowed' error regardless of storage backend."
          },
          "response": []
        }
      ]
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  }
}
