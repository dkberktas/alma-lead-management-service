                  "description": "Filter by action",
                  "disabled": true
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "offset",
                  "value": "0"
                }
              ]
            },
            "description": "Admin-only: view the full audit trail with optional filters for entity_type and action.",
            "auth": {
              "type": "bearer",
