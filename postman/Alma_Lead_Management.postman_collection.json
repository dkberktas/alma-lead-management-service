{
  "info": {
    "name": "Alma Lead Management",
    "description": "API collection for the Alma Lead Management Service.\n\n## Setup\n1. Start the app (admin is seeded via ADMIN_EMAIL / ADMIN_PASSWORD env vars)\n2. Login to get a JWT token — it's auto-saved to the `token` variable\n3. Use authenticated endpoints (leads list, admin, etc.)\n\n## Storage Backend\nResume uploads are stored in S3. Set `S3_BUCKET` in your `.env`.\n\n## Variables\n- `base_url` — defaults to `http://localhost:8000`\n- `token` — set automatically after login",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "lead_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "resume_url",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            },
            "description": "Simple health check — returns `{\"status\": \"ok\"}`."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "    pm.test('Token saved to collection variable', function () {",
                  "        pm.expect(json.access_token).to.be.a('string');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@alma.com\",\n  \"password\": \"change-me-in-production\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Authenticate and receive a JWT. The token is auto-saved to the `token` collection variable."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead (Public)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set('lead_id', json.id);",
                  "    pm.collectionVariables.set('resume_url', json.resume_url);",
                  "    pm.test('Lead ID saved to collection variable', function () {",
                  "        pm.expect(json.id).to.be.a('string');",
                  "    });",
                  "    pm.test('Resume URL points to auth-protected endpoint', function () {",
                  "        pm.expect(json.resume_url).to.be.a('string');",
                  "        pm.expect(json.resume_url).to.include('/api/leads/');",
                  "        pm.expect(json.resume_url).to.include('/resume-url');",
                  "    });",
                  "    pm.test('Raw resume_path is not exposed', function () {",
                  "        pm.expect(json).to.not.have.property('resume_path');",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "first_name",
                  "value": "Jane",
                  "type": "text"
                },
                {
                  "key": "last_name",
                  "value": "Doe",
                  "type": "text"
                },
                {
                  "key": "email",
                  "value": "jane.doe@example.com",
                  "type": "text"
                },
                {
                  "key": "resume",
                  "type": "file",
                  "src": "",
                  "description": "Select a PDF or DOCX file"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/leads",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"]
            },
            "description": "Public endpoint — submit a prospect lead with a resume file. No authentication required. The created lead ID is auto-saved to the `lead_id` variable."
          },
          "response": []
        },
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/leads",
              "host": ["{{base_url}}"],
              "path": ["api", "leads"]
            },
            "description": "List all leads. Requires JWT authentication.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Lead by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/leads/{{lead_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "leads", "{{lead_id}}"]
            },
            "description": "Get a single lead by its UUID. Requires JWT authentication.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Lead State",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"state\": \"REACHED_OUT\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/leads/{{lead_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "leads", "{{lead_id}}"]
            },
            "description": "Transition a lead from PENDING to REACHED_OUT. Requires JWT authentication.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Resume Download URL",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var json = pm.response.json();",
                  "    pm.test('Response contains a download URL', function () {",
                  "        pm.expect(json).to.have.property('url');",
                  "        pm.expect(json.url).to.be.a('string');",
                  "        pm.expect(json.url).to.have.length.above(0);",
                  "    });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/leads/{{lead_id}}/resume-url",
              "host": ["{{base_url}}"],
              "path": ["api", "leads", "{{lead_id}}", "resume-url"]
            },
            "description": "Get a short-lived (5-minute) presigned download URL for a lead's resume. Requires JWT authentication (admin or attorney). The returned URL can be opened directly in a browser to download the file.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Lead Audit Log",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/leads/{{lead_id}}/audit-log",
              "host": ["{{base_url}}"],
              "path": ["api", "leads", "{{lead_id}}", "audit-log"]
            },
            "description": "Admin-only: view the audit trail for a specific lead (state changes, creation, etc.).",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
