            "url": {
              "raw": "{{base_url}}/api/admin/users/{{user_id}}/deactivate",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "users", "{{user_id}}", "deactivate"]
            },
            "description": "Admin-only: soft-delete a user. The user can no longer log in but the account is preserved.",
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            }
          },
