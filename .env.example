# Database
DATABASE_URL=postgresql+asyncpg://alma:alma_dev_password@db:5432/alma_leads

# Auth
SECRET_KEY=change-me-to-a-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=change-me
EMAIL_FROM=noreply@alma.com
ATTORNEY_EMAIL=attorney@alma.com

# File uploads
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# Admin seed (optional — creates an admin user on first startup if set)
ADMIN_EMAIL=admin@alma.com
ADMIN_PASSWORD=change-me-in-production

# Attorney seed (optional — creates an attorney user on first startup if set)
SEED_ATTORNEY_EMAIL=attorney@alma.com
SEED_ATTORNEY_PASSWORD=change-me-in-production
